-- 🎄 LU HUB PROMPTS RP – TEMA DE NATAL 🎅
local Players = game:GetService("Players")
local StarterGui = Instance.new("ScreenGui")
StarterGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")
StarterGui.ResetOnSpawn = false
StarterGui.Name = "LuHubRPNatal"

-- ⚡ Função de copiar + aviso natalino
local function copy(text)
    setclipboard(text)

    local Notify = Instance.new("TextLabel")
    Notify.Parent = StarterGui
    Notify.Size = UDim2.new(0, 260, 0, 45)
    Notify.Position = UDim2.new(0.5, -130, 0.1, 0)
    Notify.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Notify.TextColor3 = Color3.fromRGB(0, 0, 0)
    Notify.Font = Enum.Font.GothamBold
    Notify.TextSize = 16
    Notify.Text = "🎄 Texto copiado! Feliz Natal! 🎅✨"
    Notify.BorderSizePixel = 0

    local UICorner = Instance.new("UICorner")
    UICorner.Parent = Notify
    UICorner.CornerRadius = UDim.new(0, 12)

    -- Luzinhas natalinas piscando
    for i = 1, 3 do
        Notify.BorderColor3 = Color3.fromRGB(255, 0, 0)
        Notify.BorderSizePixel = 2
        task.wait(0.15)
        Notify.BorderColor3 = Color3.fromRGB(0, 255, 0)
        task.wait(0.15)
    end

    -- Fade out
    task.delay(1.6, function()
        for i = 1, 20 do
            Notify.TextTransparency = i/20
            Notify.BackgroundTransparency = i/20
            task.wait(0.05)
        end
        Notify:Destroy()
    end)
end

